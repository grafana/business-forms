{
  "name": "business-forms",
  "description": "Insert, update application data, and modify configuration",
  "version": "6.3.3",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "start": "docker compose --profile dev up",
    "stop": "docker compose down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --maxWorkers 4 --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile playwright up --force-recreate --abort-on-container-exit --exit-code-from playwright",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.6.1",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.32",
    "@swc/helpers": "^0.5.21",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-webpack-plugin": "^5.0.3",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.8.3",
    "util": "^0.12.5",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^6.0.0",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "brace-expansion": "^1.1.14",
    "flatted": "^3.4.2",
    "lodash": "^4.18.1",
    "postcss": "^8.5.12",
    "protocol-buffers-schema": "^3.6.1",
    "protobufjs": "^7.5.6",
    "serialize-javascript": "^7.0.5"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "^12.4.2",
    "@grafana/runtime": "^12.4.2",
    "@grafana/scenes": "^7.4.2",
    "@grafana/ui": "^12.4.2",
    "@hello-pangea/dnd": "^18.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.7.4",
    "tslib": "^2.8.1",
    "uuid": "^13.0.0"
  }
}
